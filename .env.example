# Root .env.local — used by the DB tooling in ./scripts (migrate, smoke test).
# Copy to .env.local and fill in your Supabase project values. NEVER commit real values.

# Project API (also used by the smoke test to sign in as real users)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only secrets — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Dashboard > Project Settings > Database > Connection string (use the session pooler URI)
DATABASE_URL=postgresql://postgres.your-project-ref:your-db-password@aws-1-REGION.pooler.supabase.com:5432/postgres
